# ==============================================================================
# INIQ - Interview Intelligence Platform
# Environment Configuration Template
# ==============================================================================
# This file serves as a template for your local .env file.
# Copy this file to .env and update the values to match your environment.
# Note: Variables prefixed with VITE_ are accessible in your client-side code.

# --- [ Application Settings ] ---
# The human-readable name of the application.
VITE_APP_NAME=INIQ
# The current environment (e.g., development, staging, production).
VITE_APP_ENV=development

# --- [ API Configuration ] ---
# The base URL for all backend API requests.
VITE_API_BASE_URL=http://localhost:8080/api
# Request timeout in milliseconds (10 seconds by default).
VITE_API_TIMEOUT=10000

# --- [ Authentication & Session ] ---
# Local storage/Cookie key used for storing the JWT token.
VITE_AUTH_TOKEN_KEY=iniq_token
# Local storage/Cookie key used for storing basic user information.
VITE_AUTH_USER_KEY=iniq_user
# Key for storing the user's role (e.g., admin, user).
VITE_USER_ROLE_KEY=iniq_role

# --- [ Feature Toggles ] ---
# Controls access to administrative dashboards and functions.
VITE_ENABLE_ADMIN=true
# Enables the feature to upload interview or practice videos.
VITE_ENABLE_VIDEO_UPLOAD=true
# Allows embedding external video content (e.g., Loom, YouTube).
VITE_ENABLE_VIDEO_EMBED=true
# Controls the visibility of the 'Request Company Access' feature.
VITE_ENABLE_COMPANY_REQUEST=true

# --- [ System Constraints & Limits ] ---
# Maximum size allowed for video uploads in megabytes (MB).
VITE_MAX_VIDEO_SIZE_MB=50
# Global character limit for code submissions/responses.
VITE_MAX_CODE_LENGTH=10000
# Maximum number of interview rounds allowed per session.
VITE_MAX_ROUNDS=10

# --- [ Security & Compliance ] ---
# Comma-separated list of permitted video provider domains.
VITE_ALLOWED_VIDEO_DOMAINS=youtube.com,youtu.be,loom.com,drive.google.com

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
